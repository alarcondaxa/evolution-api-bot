# URL pública do servidor onde a Evolution API está rodando
# Exemplo: https://evolution-api-bot-production.up.railway.app
SERVER_URL=https://SEU_DOMINIO_RAILWAY.up.railway.app

# Chave de autenticação da API (crie uma senha forte)
AUTHENTICATION_API_KEY=minha_chave_secreta_aqui

# URL do webhook do seu site (onde a Evolution API vai enviar as mensagens recebidas)
# Exemplo: https://eqportal-etzzmwaf.manus.space/api/webhook/evolution
WEBHOOK_URL=https://eqportal-etzzmwaf.manus.space/api/webhook/evolution
